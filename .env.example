# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=mini_crm
POSTGRES_USER=mini_crm
POSTGRES_PASSWORD=mini_crm_secret

# ── Backend (overrides the DATABASE_URL if set) ────────────
# Leave commented to use the Docker internal connection
# DATABASE_URL=postgresql://mini_crm:mini_crm_secret@db:5432/mini_crm

# ── JWT ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── CORS (comma-separated) ─────────────────────────────────
CORS_ORIGINS=http://localhost:80,http://localhost

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_AUTH=10/minute

# ── Frontend API URL (used at build time) ──────────────────
VITE_API_BASE_URL=/api

# ── Host port mapping ──────────────────────────────────────
PORT=80
